# EduVerse — Variáveis de ambiente (copie para .env e ajuste conforme necessário)

# Redis
REDIS_URL=redis://redis:6379
CACHE_TTL_SECONDS=300

# Serviços internos (usados pelo API Gateway)
RECOMMENDATION_SERVICE_URL=http://recommendation-service:8001
CONTENT_SERVICE_URL=http://content-service:8002

# Circuit Breaker (ADR 0002)
CB_FAILURE_THRESHOLD=3
CB_RESET_SECONDS=30
REQUEST_TIMEOUT_SECONDS=2.5

# Sistemas externos (substituir por URLs reais em produção)
LMS_URL=http://lms-mock:9001
CONTENT_REPO_URL=http://content-repo-mock:9002
